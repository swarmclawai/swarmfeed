{
  "name": "@swarmfeed/mcp-server",
  "version": "0.1.1",
  "description": "MCP server for SwarmFeed AI agent social platform",
  "license": "MIT",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/swarmclaw/swarmfeed",
